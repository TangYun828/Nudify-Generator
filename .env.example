# ============================================
# AWS REKOGNITION & S3 CONFIGURATION (Layer 3 + 4)
# ============================================
# Required for:
# - Layer 3 (Inference): AWS Rekognition content moderation
# - Layer 4 (Audit): S3/R2 image storage for 6-month retention

# AWS Credentials (from AWS IAM Console)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1

# S3 Bucket for audit trail (create in AWS S3 or Cloudflare R2)
# Naming convention: {project}-audit-images
AWS_S3_BUCKET=intimai-audit-images

# Optional: Cloudflare R2 Endpoint (use if storing on R2 instead of S3)
# If using R2, set this to your R2 endpoint URL
# R2_ENDPOINT_URL=https://{account_id}.r2.cloudflarestorage.com

# ============================================
# AWS IAM PERMISSIONS REQUIRED
# ============================================
# Your AWS user/role needs these permissions:
# 
# 1. AWS Rekognition:
#    - rekognition:DetectModerationLabels
#
# 2. AWS S3:
#    - s3:PutObject (for uploading images)
#    - s3:GetObject (for retrieving images)
#    - s3:ListBucket (optional, for bucket management)
#
# Example IAM Policy (attach to your user):
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": [
#         "rekognition:DetectModerationLabels"
#       ],
#       "Resource": "*"
#     },
#     {
#       "Effect": "Allow",
#       "Action": [
#         "s3:PutObject",
#         "s3:GetObject",
#         "s3:ListBucket"
#       ],
#       "Resource": [
#         "arn:aws:s3:::intimai-audit-images",
#         "arn:aws:s3:::intimai-audit-images/*"
#       ]
#     }
#   ]
# }

# ============================================
# COST ESTIMATES (as of 2024)
# ============================================
# AWS Rekognition DetectModerationLabels:
#   - First 5,000 images/month: FREE
#   - After that: $0.001 per image ($1.00 per 1,000 images)
#
# AWS S3 Storage:
#   - First 50 GB: $0.023 per GB/month (~$1.15/month for 50GB)
#   - Average image: ~500KB = 2,000 images per GB
#   - 6-month retention of 10,000 images = ~5GB = $0.12/month
#
# Data Transfer (S3 → RunPod):
#   - Within same region: FREE
#   - Cross-region: $0.01-0.09 per GB
#
# Total estimated cost (10,000 images/month):
#   - Rekognition: $5.00/month (5,000 free + 5,000 paid)
#   - S3 storage: $0.12/month (5GB)
#   - Total: ~$5.12/month

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Create AWS Account (if you don't have one)
#    → https://aws.amazon.com/free
#
# 2. Create IAM User with Rekognition + S3 permissions
#    → AWS Console → IAM → Users → Add User
#    → Attach policy above (or use AWS-managed policies)
#    → Security credentials → Create access key
#
# 3. Create S3 Bucket
#    → AWS Console → S3 → Create bucket
#    → Name: intimai-audit-images
#    → Region: us-east-1 (same as RunPod for free transfer)
#    → Enable versioning + encryption (recommended)
#
# 4. Set S3 Lifecycle Rule (automatic cleanup after 6 months)
#    → Bucket → Management → Lifecycle rules
#    → Create rule: Delete objects after 180 days
#
# 5. Copy credentials to this .env file
#    → Replace placeholders above with your actual keys
#
# 6. Deploy to RunPod
#    → Add these environment variables to RunPod template
#    → Restart worker to apply changes

# ============================================
# ALTERNATIVE: CLOUDFLARE R2
# ============================================
# If you prefer Cloudflare R2 (S3-compatible, cheaper):
# 1. Create R2 bucket at dash.cloudflare.com
# 2. Get API credentials (R2 → Manage R2 API Tokens)
# 3. Set:
#    AWS_ACCESS_KEY_ID={your R2 access key}
#    AWS_SECRET_ACCESS_KEY={your R2 secret key}
#    R2_ENDPOINT_URL=https://{account_id}.r2.cloudflarestorage.com
#    AWS_S3_BUCKET={your R2 bucket name}
#
# R2 Pricing (10,000 images):
#   - Storage: 10 GB free, then $0.015/GB
#   - Operations: 10M writes free per month
#   - Egress: FREE (vs AWS $0.09/GB)
#   - Total: $0/month (within free tier)

# ============================================
# TESTING
# ============================================
# Test AWS Rekognition connection:
#   python safety_checker.py /path/to/test/image.png
#
# Test S3 upload:
#   python s3_uploader.py /path/to/image.png test_user_id "test prompt"
#
# Check logs for:
#   ✓ AWS Rekognition client initialized
#   ✓ S3 uploader initialized
#   ✓ Image passed safety check
#   ✓ Uploaded to S3: s3://bucket/key
